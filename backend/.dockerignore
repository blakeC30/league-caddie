# Virtual environments
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment files — never bake secrets into the image
.env
.env.*
!.env.example

# Dev/test files — not needed at runtime
tests/
*.md
README*

# Alembic migrations — run separately; not needed in the image
# (Keep this commented out if you run migrations from the container CMD)
# alembic/

# Docker artifacts
Dockerfile*
.dockerignore

# Scripts — dev-only utilities
scripts/

# Editor + OS noise
.git/
.gitignore
.DS_Store
.idea/
.vscode/
*.swp
*.swo
